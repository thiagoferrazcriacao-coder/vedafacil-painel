{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.js": { "maxDuration": 60, "memory": 2048 },
    "api/zapsign-send.js": { "maxDuration": 30, "memory": 512 }
  },
  "rewrites": [
    { "source": "/api/zapsign-send/:path*", "destination": "/api/zapsign-send" },
    { "source": "/api/medicoes/:path*", "destination": "/api/index.js" },
    { "source": "/api/orcamentos/:path*", "destination": "/api/index.js" },
    { "source": "/api/contratos/:path*", "destination": "/api/index.js" },
    { "source": "/api/config/:path*", "destination": "/api/index.js" },
    { "source": "/api/auth/:path*", "destination": "/api/index.js" },
    { "source": "/api/usuarios/:path*", "destination": "/api/index.js" },
    { "source": "/api/medicao/:path*", "destination": "/api/index.js" },
    { "source": "/api/medicao", "destination": "/api/index.js" },
    { "source": "/api/calendar/:path*", "destination": "/api/index.js" },
    { "source": "/api/garantias/:path*", "destination": "/api/index.js" },
    { "source": "/api/equipes/:path*", "destination": "/api/index.js" },
    { "source": "/api/equipes", "destination": "/api/index.js" },
    { "source": "/api/ordens-servico/:path*", "destination": "/api/index.js" },
    { "source": "/api/ordens-servico", "destination": "/api/index.js" },
    { "source": "/api/aplicador/:path*", "destination": "/api/index.js" },
    { "source": "/api/aplicador", "destination": "/api/index.js" },
    { "source": "/api/aplicador/:path*", "destination": "/api/index.js" },
    { "source": "/api/aplicador", "destination": "/api/index.js" },
    { "source": "/api/dashboard/:path*", "destination": "/api/index.js" },
    { "source": "/api/dashboard", "destination": "/api/index.js" },
    { "source": "/api/croqui/:path*", "destination": "/api/index.js" },
    { "source": "/api/croqui", "destination": "/api/index.js" },
    { "source": "/api/lixeira/:path*", "destination": "/api/index.js" },
    { "source": "/api/lixeira", "destination": "/api/index.js" },
    { "source": "/api/reparos/:path*", "destination": "/api/index.js" },
    { "source": "/api/reparos", "destination": "/api/index.js" },
    { "source": "/api/debug-zapsign", "destination": "/api/index.js" },
    { "source": "/api/produtos/:path*", "destination": "/api/index.js" },
    { "source": "/api/produtos", "destination": "/api/index.js" },
    { "source": "/api/me", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
