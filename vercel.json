{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.js": { "maxDuration": 60, "memory": 2048 },
    "api/zapsign-send.js": { "maxDuration": 30, "memory": 512 }
  },
  "rewrites": [
    { "source": "/api/zapsign-send", "destination": "/api/zapsign-send.js" },
    { "source": "/api/((?!zapsign-send).*)", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
